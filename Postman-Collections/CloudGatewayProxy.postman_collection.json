  "item": [
    {
      "name": "Gateway hacia Catalogue",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Gateway enruta correctamente a Catalogue - Status 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response es un array de libros\", function () {\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body).to.be.an('array');\r",
              "});\r",
              "\r",
              "pm.test(\"Tiempo de respuesta menor a 3000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
