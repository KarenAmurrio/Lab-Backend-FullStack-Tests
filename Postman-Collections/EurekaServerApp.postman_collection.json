  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Eureka está corriendo - Status 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Estado del servicio es UP\", function () {\r",
              "    const body = pm.response.json();\r",
              "    pm.expect(body.status).to.equal(\"UP\");\r",
              "});\r",
              "\r",
              "pm.test(\"Tiempo de respuesta menor a 2000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8761/actuator/health",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8761",
          "path": [
            "actuator",
            "health"
          ]
        }
      },
      "response": []
